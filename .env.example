# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@healthy_normal        # channel users must subscribe to
TELEGRAM_ADMIN_IDS=123456789,987654321     # comma-separated admin telegram IDs

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/calories_bot
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/calories_bot

# ── AI: Text + Vision model ───────────────────────────────────────────────────
TEXT_MODEL_PROVIDER=openai
TEXT_MODEL_NAME=openai/gpt-4o-mini        # polza.ai format: openai/gpt-4o-mini
VISION_MODEL_PROVIDER=openai
VISION_MODEL_NAME=openai/gpt-4o           # polza.ai format: openai/gpt-4o

# ── AI: STT (Speech-to-Text) ──────────────────────────────────────────────────
STT_PROVIDER=openai
STT_MODEL_NAME=openai/whisper-1           # polza.ai format: openai/whisper-1

# ── AI API (OpenAI or polza.ai or any OpenAI-compatible provider) ──────────────
OPENAI_API_KEY=pza_...                    # polza.ai key starts with pza_
OPENAI_BASE_URL=https://polza.ai/api/v1   # default: https://api.openai.com/v1

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                        # development | production
LOG_LEVEL=INFO
WEBHOOK_URL=                               # set in production, e.g. https://yourapp.railway.app
WEBHOOK_PATH=/webhook
APP_HOST=0.0.0.0
APP_PORT=8000
