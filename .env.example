# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@healthy_normal        # channel users must subscribe to
TELEGRAM_ADMIN_IDS=123456789,987654321     # comma-separated admin telegram IDs

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/calories_bot
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/calories_bot

# ── AI: Text + Vision model ───────────────────────────────────────────────────
TEXT_MODEL_PROVIDER=openai                 # openai | anthropic (future)
TEXT_MODEL_NAME=gpt-4o-mini
VISION_MODEL_PROVIDER=openai
VISION_MODEL_NAME=gpt-4o

# ── AI: STT (Speech-to-Text) ──────────────────────────────────────────────────
STT_PROVIDER=openai                        # openai (whisper)
STT_MODEL_NAME=whisper-1

# ── OpenAI API key ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                        # development | production
LOG_LEVEL=INFO
WEBHOOK_URL=                               # set in production, e.g. https://yourapp.railway.app
WEBHOOK_PATH=/webhook
APP_HOST=0.0.0.0
APP_PORT=8000
